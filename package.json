    "eslint-plugin-react-hooks": "4.5.0",
    "node-plop": "0.31.1",
    "plop": "^2",
    "postcss": "^8.4.12",
    "prettier": "2.8.8",
    "stylelint": "14.16.1",
    "stylelint-config-recommended": "7.0.0",
