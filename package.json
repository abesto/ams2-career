    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^1.4.0",
    "xml2js": "0.6.2"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "test": "vitest --typecheck",
    "test:ui": "vitest --typecheck --ui",
    "start:prod": "vite preview",
    "test:generators": "ts-node ./internals/testing/generators/test-generators.ts",
    "checkTs": "tsc --noEmit",
    "eslint": "eslint --ext js,ts,tsx",
    "lint": "pnpm run eslint src",
    "lint:fix": "pnpm run eslint --fix src",
    "lint:css": "stylelint src/**/*.css",
    "generate": "plop --plopfile internals/generators/plopfile.ts",
    "prettify": "prettier --write",
    "extract-messages": "i18next-scanner --config=internals/extractMessages/i18next-scanner.config.js",
    "prepare": "husky install",
    "update-data": "ts-node ./internals/updateData/index.ts",
    "extract-game-data": "ts-node internals/extractGameData/main.ts"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=14.x"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "pnpm run eslint --fix"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
  }
}
